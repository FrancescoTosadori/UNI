package it.unibs.fp.puntirette;

public class Retta {

	private static final double EPSILON = 0.00001;
	private double coeffAngolare;
	private double offset;
	private boolean verticale;
	
	public Retta(Punto p1, Punto p2) {
		//siccome lavoriamo con dei float, facciamo il valore assoluto della differenza del .
		if(Math.abs(p1.getX() - p2.getX()) < EPSILON) {
			verticale = true;
		}
		else {
			verticale = false;
		}
		
		//se la retta non è verticale, calcoliamo i parametri.
		if(verticale) {
			coeffAngolare = 0;
		} else {
			coeffAngolare = (p2.getY() - p1.getY()) /
					(p2.getX() - p1.getY());
		}
		
		offset = p2.getY() - coeffAngolare * p2.getX();
	}
	
	
}
