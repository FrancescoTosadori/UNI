package it.unibs.fp.renderer;

public class Vector {
	private double x, y, z;
	
	public Vector(double x, double y, double z) {
		this.x = x;
		this.y = y;
		this.z = z;
	}
	
	public Vector(Point A, Point B) {
		this.x = B.getX() - A.getX();
		this.y = B.getY() - A.getY();
		this.z = B.getZ() - A.getZ();
	}
	
	
	public double getX() {
		return x;
	}



	public void setX(double x) {
		this.x = x;
	}



	public double getY() {
		return y;
	}



	public void setY(double y) {
		this.y = y;
	}



	public double getZ() {
		return z;
	}



	public void setZ(double z) {
		this.z = z;
	}

	
	public double scalar_product(Vector v) {
		return (x*v.getX() + y*v.getY() + z*v.getZ());
	}
	
	public double scalar_product() {
		return (x*x + y*y + z*z);
	}
	
	
	public double norm() {
		return Math.sqrt(scalar_product());
	}
	

	public void normalise() {
		double norm = norm();
		x /= norm;
		y /= norm;
		z /= norm;
	}
	
	public void scale(double scalar) {
		x *= scalar;
		y *= scalar;
		z *= scalar;
	}
	
	public Vector scaled(double scalar) {
		Vector v = new Vector(x, y, z);
		v.setX(v.getX() * scalar);
		v.setY(v.getY() * scalar);
		v.setZ(v.getZ() * scalar);
		
		return v;
	}
	
	
	public void sum(Vector v) {
		x += v.getX();
		y += v.getY();
		z += v.getZ();
	}
	
}
