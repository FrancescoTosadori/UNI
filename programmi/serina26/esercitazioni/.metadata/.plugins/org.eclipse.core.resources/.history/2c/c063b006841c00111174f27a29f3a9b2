package it.unibs.fp.renderer;

public class RendererMain {

	public static void main(String[] args) {
		Vector r = new Vector(1,1,1);
		Vector y = new Vector(0,0,0);
		Vector x = new Vector(0,0,0);
		double radius = 1;
		
		r.normalise();
		r.scale(radius);
		
		y.setX(1);
		y.setY(r.getY() / r.getX());
		y.setZ(r.getZ() * y.get());
		y.normalise();
		
	}
	
	private double module_of_xy_projection(double x, double y) {
		return Math.sqrt(x*x + y*y);
	}

}
