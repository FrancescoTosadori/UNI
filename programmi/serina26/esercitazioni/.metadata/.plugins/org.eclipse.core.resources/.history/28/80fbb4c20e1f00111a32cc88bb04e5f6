package it.unibs.fp.renderer;

public class Screen {
	private int i, j;
	private final int DIMR = 8, DIMC = 6;
	private char[][] mat = new char[DIMR][DIMC];
	private final double ALPHA = Math.toRadians(120);
	private final double BETA = Math.toRadians(90);
	
	public void clear() {
		for(i = 0; i < DIMR; i++) {
			for(j = 0; j < DIMC; j++) {
				mat[i][j] = '.';
			}
		}
	}
	
	public void drawPoint(Point p, Vector r) {
		//Troviamo il punto p sul piano di vettore normale r scalando r in modo che P + r*scalare soddisfi l'equazione del piano.
		Point p_perp = new Point(p);
		double alpha = r.scalar_product(Vector()) /
		p_perp.add_vector(r.scale());
		
	}
	
	public void print() {
		System.out.print("\033[H\033[2J");  //questo comando pulisce il terminale ma non so perché; l'ho rubato da stackoverflow
	    System.out.flush();
		for(i = 0; i < DIMR; i++) {
			for(j = 0; j < DIMC; j++) {
				System.out.print(mat[i][j]);
			}
			System.out.println("\n");
		}
	}

	//questa funzione prende un intervallo espresso in double e un valore al suo interno, per poi mapparlo ad un valore proporzionale compreso in un intervallo espresso in int 
	private int map(double value, double a0, double a1, int x0, int x1) {
		double quotient = (value - a0) / (a1 - a0);
		int output = (int)(quotient * (x1 - x0)) + x0;
		return output;
	}
}
