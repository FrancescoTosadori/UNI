package it.unibs.fp.renderer;

public class Vector {
	private double x;
	private double y;
	private double z;
	
	public Vector(double x, double y, double z) {
		this.x = x;
		this.y = y;
		this.z = z;
	}
	
	public void normalise() {
		double norm = Math.sqrt(
				x*x +
				y*y +
				z*z);
		x /= norm;
		y /= norm;
		z /= norm;
	}
	
	public void scale(double scalar) {
		x *= scalar;
		y *= scalar;
		z *= scalar;
	}
}
