package it.unibs.fp.renderer;

public class Screen {
	private int i, j;
	private final int DIMR = 8, DIMC = 6;
	private char[][] mat = new char[DIMR][DIMC];
	private final double ALPHA = Math.toRadians(120);
	private final double BETA = Math.toRadians(90);
	
	public void clear() {
		for(i = 0; i < DIMR; i++) {
			for(j = 0; j < DIMC; j++) {
				mat[i][j] = '.';
			}
		}
	}
	
	public void drawPoint(Point p, Vector r, double radius) {
		double k = (r.getX()*(r.getX() - p.getX()) + r.getY()*(r.getY() - p.getY()) + r.getZ()*(r.getZ() - p.getZ())) / (r.getX()*r.getX() + r.getY()*r.getY() + r.getZ()*r.getZ()); //scalare per cui bisogna moltiplicare i parametri direttori della retta perp. al piano e passante per il punto p.
		
		Point p_perp = new Point(
				p.getX() + k * r.getX(),
				p.getY() + k * r.getY(),
				p.getZ() + k * r.getZ()
				);
				
		//Abbiamo trovato p_perp, la proiezione di P sul piano della "telecamera". Dobbiamo ora creare un sistema di coordinate sul piano e calcolare le componenti di p_perp rispetto ad esso. L'origine sarà fissata nel punto dove il piano è tangente alla sfera. Ci servirà un vettore direzionale che punti verso l'asse delle z (e quindi abbia componenti x ed y parallele linearmente dipendenti dalle comp. xy del vettore raggio). La componente z sarà ricavata usando i triangoli simili.
	}
	
	public void print() {
		System.out.print("\033[H\033[2J");  //questo comando pulisce il terminale ma non so perché; l'ho rubato da stackoverflow
	    System.out.flush();
		for(i = 0; i < DIMR; i++) {
			for(j = 0; j < DIMC; j++) {
				System.out.print(mat[i][j]);
			}
			System.out.println("\n");
		}
	}
	
	//questa funzione prende un intervallo espresso in double e un valore al suo interno, per poi mapparlo ad un valore proporzionale compreso in un intervallo espresso in int 
	private int map(double value, double a0, double a1, int x0, int x1) {
		double quotient = (value - a0) / (a1 - a0);
		int output = (int)(quotient * (x1 - x0)) + x0;
		return output;
	}
}
